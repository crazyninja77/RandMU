{
  "name": "randmu-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "seed": "tsx src/seed.ts",
    "harvest": "tsx src/harvest.ts",
    "ingest": "tsx src/ingest.ts",
    "ingest:playlists": "tsx src/ingest.ts --from-playlists",
    "ingest:musicbrainz": "tsx src/ingest.ts --from-musicbrainz",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
